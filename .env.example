# local-demo keeps the current browser/localStorage demo working.
# supabase enables the production backend path once Supabase credentials are set.
VITE_DATA_MODE="local-demo"

# Keep the production choice reversible. single-tenant locks the UI and login
# to Anastassiadis; multi-tenant enables Atlas PM platform administration.
VITE_PRODUCT_MODE="single-tenant"
VITE_SINGLE_TENANT_ID="10000000-0000-4000-8000-000000000011"
VITE_SINGLE_TENANT_NAME="Anastassiadis Group"

# Supabase project settings.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Public app URL for auth redirects and payment callbacks.
VITE_APP_URL="http://localhost:3000"

# Express API server port (default: 3001).
API_PORT=3001
NODE_ENV="development"
# Comma-separated trusted browser origins. Production entries must use HTTPS.
APP_ORIGINS="http://localhost:3000"
API_PUBLIC_URL="http://localhost:3001"
CRON_SECRET=""
FILE_SCAN_API_URL=""
FILE_SCAN_API_KEY=""
# Demo API fallback is ignored in production and should stay false in deployments.
ALLOW_DEMO_API="true"

# Server-side Supabase credentials — used by the API to VERIFY bearer tokens
# (requireAuth middleware) and read authoritative data. Never prefixed with
# VITE_ (must not reach the browser). When these are empty the API runs in
# DEMO mode with authentication NOT enforced.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# One-time launch input for `npm run provision:users`; use passwords of 12+ chars,
# run locally, then remove this value and rotate the service-role key.
PROVISION_USERS_JSON=""

# Viva Wallet Smart Checkout (server-side only — never expose to frontend).
# Leave empty to run in demo mode (generates placeholder links).
VIVAWALLET_SANDBOX="true"
VIVAWALLET_CLIENT_ID=""
VIVAWALLET_CLIENT_SECRET=""
VIVAWALLET_SOURCE_CODE=""
VIVAWALLET_WEBHOOK_KEY=""

# Optional feature integrations. Blank values keep explicit demo mode active.
MYDATA_DEMO="true"
AADE_USER_ID=""
AADE_SUBSCRIPTION_KEY=""
ANTHROPIC_API_KEY=""
ANTHROPIC_OCR_MODEL="claude-3-5-haiku-latest"
RESEND_API_KEY=""
EMAIL_FROM="Atlas PM <notifications@YOUR_DOMAIN>"
# Generic JSON SMS adapter: POST { from, to, text } with a Bearer token.
SMS_PROVIDER=""
SMS_API_URL=""
SMS_API_KEY=""
SMS_FROM="AtlasPM"
AADE_API_URL="https://mydatapi.aade.gr/myDATA"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
