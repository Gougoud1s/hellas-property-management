# local-demo keeps the current browser/localStorage demo working.
# supabase enables the production backend path once Supabase credentials are set.
VITE_DATA_MODE="local-demo"

# Supabase project settings.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Public app URL for auth redirects and payment callbacks.
VITE_APP_URL="http://localhost:3000"
